<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ splash screen icon. Bitmap is already tight-cropped to the
  rounded-square logo, so we render it edge-to-edge inside the system's
  icon container — no inset, no white halo.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/app_logo"
    android:gravity="fill" />
