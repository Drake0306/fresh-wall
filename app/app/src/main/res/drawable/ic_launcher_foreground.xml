<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground. The logo bitmap is tight-cropped (no transparent
  padding around the rounded square), so we point at it directly without an
  inset wrapper — the bitmap fills the 108dp adaptive viewport edge-to-edge
  and the launcher's mask shape cuts whatever it cuts. The pre-cropped art
  keeps the visible "icon" flush with the mask, with no cream halo around it.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/app_logo"
    android:gravity="fill" />
